rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check user role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Users collection - read own profile, create own profile
    match /users/{userId} {
      allow read: if request.auth.uid == userId || request.auth.uid != null;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
      allow delete: if false; // Never delete users
    }

    // Batches - farmers can create, all authenticated users can read
    match /batches/{batchId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
        (getUserRole() == 'farmer' || getUserRole() == 'admin');
      allow update: if request.auth != null && 
        (getUserRole() == 'farmer' || getUserRole() == 'admin' || getUserRole() == 'lab');
      allow delete: if request.auth != null && getUserRole() == 'admin';
    }

    // Lab Tests - lab users can create, all can read
    match /labTests/{testId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
        (getUserRole() == 'lab' || getUserRole() == 'admin');
      allow update: if request.auth != null && 
        (getUserRole() == 'lab' || getUserRole() == 'admin');
      allow delete: if request.auth != null && getUserRole() == 'admin';
    }

    // Products - manufacturers can create, all can read (public verification)
    match /products/{productId} {
      allow read: if true; // Public for consumer verification
      allow create: if request.auth != null && 
        (getUserRole() == 'manufacturer' || getUserRole() == 'admin');
      allow update: if request.auth != null && 
        (getUserRole() == 'manufacturer' || getUserRole() == 'admin');
      allow delete: if request.auth != null && getUserRole() == 'admin';
    }

    // Blockchain records - read by all authenticated, write by admin only
    match /blockchain/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (getUserRole() == 'admin' || getUserRole() == 'farmer' || 
         getUserRole() == 'lab' || getUserRole() == 'manufacturer');
    }

    // Waste records
    match /waste/{docId} {
      allow read: if request.auth != null && 
        (getUserRole() == 'admin' || getUserRole() == 'manufacturer');
      allow write: if request.auth != null && 
        (getUserRole() == 'admin' || getUserRole() == 'manufacturer');
    }

    // Insurance - farmers and admin
    match /insurance/{docId} {
      allow read: if request.auth != null && 
        (getUserRole() == 'farmer' || getUserRole() == 'admin');
      allow write: if request.auth != null && 
        (getUserRole() == 'farmer' || getUserRole() == 'admin');
    }

    // DNA Profiles - lab and admin
    match /dnaProfiles/{docId} {
      allow read: if request.auth != null && 
        (getUserRole() == 'lab' || getUserRole() == 'admin');
      allow write: if request.auth != null && 
        (getUserRole() == 'lab' || getUserRole() == 'admin');
    }

    // Orders - manufacturers and admin
    match /orders/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (getUserRole() == 'manufacturer' || getUserRole() == 'admin');
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
    }

    match /inventory/{docId} {
      allow read, write: if request.auth != null;
    }

    match /notifications/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}